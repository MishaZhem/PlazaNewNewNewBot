# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram chat id — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# --- Primary auth: username/password (OAuth2 password grant) ---
PLAZA_USERNAME=
PLAZA_PASSWORD=

# OAuth2 client_id. Usually "wzp". If login fails with "invalid_client",
# get the real value from browser DevTools:
#   Network → request to auth.hexia.io/api/v1/oauth/token → request payload → client_id
PLAZA_CLIENT_ID=wzp

# --- Optional fallback: session cookie ---
# If OAuth login fails (e.g. your account requires MFA), paste the full
# Cookie header value from a logged-in browser session:
#   DevTools → Network → any plaza.newnewnew.space request → Cookie header
PLAZA_SESSION_COOKIE=

# City to filter listings for
TARGET_CITY=Delft

# How often to poll for new listings (in seconds)
POLL_INTERVAL_SECONDS=60

# Set to true for safe testing — will NOT submit real applications
DRY_RUN=false
