# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram chat id — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# --- Primary auth: username/password (OAuth2 password grant) ---
PLAZA_USERNAME=
PLAZA_PASSWORD=

# OAuth2 client_id. Usually "wzp". If login fails with "invalid_client",
# get the real value from browser DevTools:
#   Network → request to auth.hexia.io/api/v1/oauth/token → request payload → client_id
PLAZA_CLIENT_ID=wzp

# --- Optional fallback: session cookie ---
# If OAuth login fails (e.g. your account requires MFA), paste the full
# Cookie header value from a logged-in browser session:
#   DevTools → Network → any plaza.newnewnew.space request → Cookie header
PLAZA_SESSION_COOKIE=

# City to filter listings for
TARGET_CITY=Delft

# How often to poll for new listings (in seconds) — legacy single value.
# Ignored when POLL_INTERVAL_MIN/MAX_SECONDS are set.
POLL_INTERVAL_SECONDS=60

# Set to true for safe testing — will NOT submit real applications
DRY_RUN=false

# ── Anti-detection / pacing ──

# Randomised poll interval — the bot sleeps a random duration in [MIN, MAX]
# between polls instead of a fixed interval. Defaults: 45–90 s.
POLL_INTERVAL_MIN_SECONDS=45
POLL_INTERVAL_MAX_SECONDS=90

# Active-hours window (Europe/Amsterdam timezone).
# The bot runs 24/7 by default (0–24, full day).
# To limit it to daytime hours, set both to a range (e.g., 7 and 24).
# The bot only polls and applies between START (inclusive) and END (exclusive).
# END=24 means the window runs until midnight.
ACTIVE_HOURS_START=0
ACTIVE_HOURS_END=24

# Human-like delay injected before each real application (not in DRY_RUN).
# A random value in [MIN, MAX] seconds is chosen per listing. Defaults: 10–60 s.
APPLY_DELAY_MIN_SECONDS=10
APPLY_DELAY_MAX_SECONDS=60

# Cooldown in seconds after a 429 / 403 rate-limit response.
# Default: 1800 s (30 min).
RATE_LIMIT_COOLDOWN_SECONDS=1800

# Path to the session persistence file (cookies + tokens).
# Defaults to session.json next to bot.py. Never commit this file.
# SESSION_FILE=/path/to/session.json
